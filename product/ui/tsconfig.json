{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "allowImportingTsExtensions": false,
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts"
  ]
}
