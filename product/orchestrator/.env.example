# Puma orchestrator — environment config (B.t6 full surface)
# Copy to .env and fill in real values. Never commit .env.
#
# Every key here is validated by src/config/schema.ts at startup. Missing
# required keys (ANTHROPIC_API_KEY) or invalid values (e.g. PORT=abc) cause a
# clean process.exit(1) with a readable Zod error — see src/config/load.ts.

# ---------------------------------------------------------------------------
# Required secret
# ---------------------------------------------------------------------------

# The Anthropic API key powering the orchestrator's Claude model.
# B.t1 validates presence at startup; B.t5+ actually call the model.
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Orchestrator agent — conversational model (decision B.5: per-agent model)
# ---------------------------------------------------------------------------

# Default is pinned in src/config/schema.ts (DEFAULT_ORCHESTRATOR_MODEL).
# Override here to test other Claude tiers without a code change.
# ORCHESTRATOR_MODEL=claude-sonnet-4-5-20250929

# Sampling temperature for the orchestrator. Range 0..2. Default: 0.7.
# ORCHESTRATOR_TEMPERATURE=0.7

# Max output tokens per orchestrator turn. Default: 2048.
# ORCHESTRATOR_MAX_TOKENS=2048

# Deprecated B.t1 alias for ORCHESTRATOR_MODEL. Still honoured for backward
# compat: if set and ORCHESTRATOR_MODEL is unset, PRIMARY_MODEL is used.
# Prefer ORCHESTRATOR_MODEL in new configs.
# PRIMARY_MODEL=claude-sonnet-4-5-20250929

# ---------------------------------------------------------------------------
# Functional classifier — lightweight internal agent (B.t7 consumes)
# ---------------------------------------------------------------------------

# Default is pinned in src/config/schema.ts (DEFAULT_CLASSIFIER_MODEL).
# FUNCTIONAL_CLASSIFIER_MODEL=claude-haiku-4-5-20250929

# Low temperature — classification wants deterministic labels. Default: 0.2.
# FUNCTIONAL_CLASSIFIER_TEMPERATURE=0.2

# ---------------------------------------------------------------------------
# Content paths (relative to product/orchestrator/, resolved at startup)
# ---------------------------------------------------------------------------

# Path to the WHY system prompt. Default: ../cms/prompts/why.md
# (chunk G.t1 owns the real content).
# SYSTEM_PROMPT_PATH=../cms/prompts/why.md

# Directory for ADK-native skill loading (B.t9 consumes).
# Default: ../cms/skills
# SKILLS_DIR=../cms/skills

# ---------------------------------------------------------------------------
# Session (B.t2 consumes; values: in-memory | adk-native | vertex-ai | firestore)
# ---------------------------------------------------------------------------

# Session-store backend. in-memory is the Phase 1 default; vertex-ai and
# firestore are stubs (post-M4). Default: in-memory.
# SESSION_BACKEND=in-memory

# Idle-to-archive TTL for the in-memory sweeper, in hours. Default: 24.
# SESSION_TTL_IDLE_HOURS=24

# Archive retention before deletion, in days. Default: 7.
# SESSION_TTL_ARCHIVE_DAYS=7

# ---------------------------------------------------------------------------
# Connector (B.t3 consumes — MCP-over-HTTP)
# ---------------------------------------------------------------------------

# MCP endpoint for the chunk C connector. Default points at the stub
# connector (product/orchestrator/test-fixtures/stub-connector.ts) so local
# dev works before chunk C lands.
# CONNECTOR_URL=http://localhost:3001/mcp

# Per-call timeout for connector tool invocations, in ms. Too short → false
# negatives; too long → breaks conversational feel. Default: 10000.
# CONNECTOR_REQUEST_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# Server (B.t5 consumes CORS)
# ---------------------------------------------------------------------------

# HTTP port for the Express process. Default: 8080.
# PORT=8080

# NODE_ENV flips hot-reload on the prompt loader and dev-only behaviours.
# In any value other than "production", the prompt re-reads from disk on every
# request and verbose logging is enabled. Default: development.
# NODE_ENV=development

# Comma-separated list of origins allowed by CORS for the SSE /chat endpoint.
# Whitespace around commas is tolerated. Default: http://localhost:5173
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://staging.swoop.example

# ---------------------------------------------------------------------------
# Warm pool (reserved — B.t10 flips defaults when wired)
# ---------------------------------------------------------------------------

# Number of pre-warmed orchestrator instances. 0 = disabled. Default: 0.
# WARM_POOL_SIZE=0

# Idle TTL for a pooled instance in minutes. Default: 30.
# WARM_POOL_TTL_MINUTES=30
