{
  "name": "@swoop/product",
  "version": "0.0.0",
  "private": true,
  "description": "Swoop Web Discovery (Puma release) — code monorepo root. See product/CLAUDE.md.",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "workspaces": [
    "ts-common",
    "orchestrator",
    "connector",
    "ui",
    "ingestion"
  ],
  "scripts": {
    "build": "bash scripts/run-workspaces.sh build",
    "typecheck": "bash scripts/run-workspaces.sh typecheck",
    "test": "bash scripts/run-workspaces.sh test",
    "lint": "eslint . --max-warnings=0 --no-error-on-unmatched-pattern",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "dev": "bash scripts/dev.sh",
    "clean": "rm -rf node_modules */node_modules */dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
